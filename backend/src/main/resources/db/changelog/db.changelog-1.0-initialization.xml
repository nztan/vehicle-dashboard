<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
           https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-vehicle-reading" author="nztan">
        <createTable tableName="vehicle_reading">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="recorded_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="motor_rpm" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="power_kw" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="battery_level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="battery_temperature" type="int">
                <constraints nullable="false"/>
            </column>

            <column name="parking_brake_ind" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="check_engine_ind" type="boolean">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

    <changeSet id="create-vehicle_setting" author="nztan">
        <createTable tableName="vehicle_setting">
            <column name="id" type="int">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="motor_speed_setting" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="charging_ind" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>