<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
           https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-vehicle_reading" author="nztan">
        <createTable tableName="vehicle_reading">
            <column name="id" type="int">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="motor_rpm" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="power_kw" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="battery_level" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="battery_temperature" type="int">
                <constraints nullable="false"/>
            </column>

            <column name="parking_brake_ind" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="check_engine_ind" type="boolean">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

    <changeSet id="create-vehicle_setting" author="nztan">
        <createTable tableName="vehicle_setting">
            <column name="id" type="int">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="motor_speed" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="charging_ind" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="initialize-vehicle_reading" author="nztan" dbms="postgresql">
        <sql>
            INSERT INTO vehicle_reading (id, motor_rpm, power_kw, battery_level, battery_temperature, parking_brake_ind, check_engine_ind)
            VALUES (1, 0, 0, 100, 20, false, false);
        </sql>
    </changeSet>

    <changeSet id="initialize-vehicle_setting" author="nztan" dbms="postgresql">
        <sql>
            INSERT INTO vehicle_setting (id, motor_speed, charging_ind)
            VALUES (1, 0, false);
        </sql>
    </changeSet>
</databaseChangeLog>